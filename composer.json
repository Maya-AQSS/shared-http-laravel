{
    "name": "maya/shared-http-laravel",
    "description": "Shared HTTP utilities for MAyA Laravel microservices: response envelope, health checks, base resources.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Maya-AQSS/shared-http-laravel",
    "support": {
        "issues": "https://github.com/Maya-AQSS/shared-http-laravel/issues",
        "source": "https://github.com/Maya-AQSS/shared-http-laravel"
    },
    "version": "0.1.0",
    "require": {
        "php": "^8.4",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Maya\\Http\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
