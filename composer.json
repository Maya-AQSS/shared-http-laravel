{
    "name": "ceedcv-maya/shared-http-laravel",
    "description": "Reusable HTTP utilities for Laravel APIs: standardized JSON response envelope, health endpoint, app metadata controller, exception handler.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Maya-AQSS/shared-http-laravel",
    "support": {
        "issues": "https://github.com/Maya-AQSS/maya_platform/issues",
        "source": "https://github.com/Maya-AQSS/shared-http-laravel"
    },
    "require": {
        "php": "^8.4",
        "illuminate/foundation": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Maya\\Http\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "laravel",
        "http",
        "api",
        "health",
        "response",
        "ceedcv",
        "maya"
    ],
    "authors": [
        {
            "name": "CEEDCV",
            "email": "info@ceedcv.es",
            "homepage": "https://ceedcv.es"
        }
    ]
}
